# ─── Privy ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# ─── Elfa AI ──────────────────────────────────────────────────────────────────
ELFA_AI_API_KEY=
NEXT_PUBLIC_ELFA_AI_BASE_URL=https://api.elfa.ai/v1

# ─── Anthropic (Market Assistant natural language — optional) ──────────────────
# Get key at console.anthropic.com. Without this, the chatbot still works
# for structured queries (trending, funding, positions) but won't answer
# free-form questions in plain English.
ANTHROPIC_API_KEY=

# ─── Pacifica DEX ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_PACIFICA_WS_URL=wss://ws.pacifica.fi/ws
NEXT_PUBLIC_PACIFICA_API_URL=https://api.pacifica.fi/api/v1
# ─── Jupiter (Spot Prices for Arb Scanner) ────────────────────────────────────
NEXT_PUBLIC_JUPITER_PRICE_API=https://price.jup.ag/v6/price
JUPITER_API_KEY=

# ─── Builder Code (DO NOT CHANGE) ─────────────────────────────────────────────
NEXT_PUBLIC_BUILDER_CODE=POINTPULSE

NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# ─── Client-side boot kill switch (optional) ──────────────────────────────────
# Set NEXT_PUBLIC_KILL_SWITCH=true to halt trading at page load (requires redeploy)
NEXT_PUBLIC_KILL_SWITCH=
NEXT_PUBLIC_KILL_SWITCH_REASON=

# ─── Server-side remote kill switch (no redeploy needed) ──────────────────────
# Change these in Vercel/Railway dashboard → takes effect within 30 seconds
# WITHOUT a redeploy (serverless functions read env vars at invocation time)
# Set KILL_SWITCH=true to halt all trading immediately
KILL_SWITCH=
KILL_SWITCH_REASON=

